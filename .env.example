# Database URL (PostgreSQL)
# Get this from your database provider (e.g., Neon, Supabase,Railway)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Optional: Auth.js secret (generated via: pnpm exec authsecret)
AUTH_SECRET="your-auth-secret-here"

# Optional: Auth.js.trustHostname (set to true if behind proxy)
AUTH_TRUST_HOST=true